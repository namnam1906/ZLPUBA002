<mvc:View xmlns:mvc="sap.ui.core.mvc" controllerName="com.cu.s4hana.zlpuba002_1.controller.PoNewHeader" xmlns:uxap="sap.uxap" xmlns="sap.m"
	xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form">
	<Page
		id="idPoNewHeaderPage"
		title="{i18n>Label.AppTitle}"
		showHeader="true" 
		showNavButton="true">
		<customHeader>
			<Bar>
				<contentLeft>
					<Button type="Back" press="handleBackPress" />
				</contentLeft>
				<contentMiddle>
					<Title text="{i18n>Label.AppTitle}"/>
				</contentMiddle>
			</Bar>
		</customHeader>
		<footer/>
	</Page>
</mvc:View>