      ls_accountx-cmmt_item       = abap_true.
*      ls_accountx-cmmt_item_long  = abap_true.
      ls_accountx-res_doc         = abap_true.
      ls_accountx-res_item        = abap_true.
      ls_accountx-quantity        = abap_true.
      APPEND ls_accountx TO lt_accountx.
    ENDLOOP.


