    DATA: lv_exppurchaseorder  TYPE  bapimepoheader-po_number,
          ls_expheader         TYPE  bapimepoheader,
          ls_exppoexpimpheader TYPE  bapieikp.

    DATA: ls_default_header     TYPE bapimepoheader,
          lt_default_item       TYPE TABLE OF bapimepoitem,
          lt_default_account    TYPE TABLE OF bapimepoaccount,
          lt_default_condheader TYPE TABLE OF bapimepocondheader,
          lt_default_cond       TYPE TABLE OF bapimepocond.

    DATA: lv_banfn TYPE eban-banfn,
          lv_bnfpo TYPE eban-bnfpo.


* Get account default value
    CALL FUNCTION 'BAPI_PO_GETDETAIL1'
      EXPORTING
        purchaseorder      = is_po_header-ebeln
        account_assignment = 'X'
      IMPORTING
        poheader           = ls_default_header
*       POEXPIMPHEADER     =
      TABLES
        poitem             = lt_default_item
        poaccount          = lt_default_account
        pocondheader       = lt_default_condheader
        pocond             = lt_default_cond.

    READ TABLE it_po_item INTO DATA(ls_first_item) INDEX 1.

* Assigns the header
    ls_header-po_number  = is_po_header-ebeln.
    ls_header-comp_code  = is_po_header-bukrs.
    ls_header-doc_type   = is_po_header-bsart.
    ls_header-memory     = is_po_header-memory.
    ls_header-vendor     = is_po_header-lifnr.
    ls_header-langu      = sy-langu.
    ls_header-purch_org  = is_po_header-ekorg.
    ls_header-pur_group  = is_po_header-ekgrp.
    ls_header-creat_date = is_po_header-bedat.
    ls_header-currency   = ls_first_item-waers. "is_po_header-waers.
    ls_header-collect_no = is_po_header-submi.
    ls_header-our_ref    = is_po_header-unsez.
    REPLACE ALL OCCURENCES OF '*' IN ls_header-our_ref WITH '/'.
    ls_header-vper_start = is_po_header-kdatb.
    ls_header-vper_end = is_po_header-kdate.

* Assigns the headerx
    ls_headerx-po_number  = abap_true.
    ls_headerx-comp_code  = abap_true.
    ls_headerx-doc_type   = abap_true.
    ls_headerx-memory     = abap_true.
    ls_headerx-vendor     = abap_true.
    ls_headerx-langu      = abap_true.
    ls_headerx-purch_org  = abap_true.
    ls_headerx-pur_group  = abap_true.
    ls_headerx-creat_date = abap_true.
    ls_headerx-currency   = abap_true.
    ls_headerx-collect_no = abap_true.
    ls_headerx-our_ref    = abap_true.
    ls_headerx-vper_start = abap_true.
    ls_headerx-vper_end = abap_true.

    CLEAR ls_condheader.
*     ls_condheader-itm_number = '000000'.
*     ls_condheader-COND_ST_NO = '021'.
*     ls_condheader-COND_COUNT = '01'.
    ls_condheader-cond_type  = 'ZVA2'.

    IF is_po_header-zva2 = abap_true.
      ls_condheader-change_id  = 'I'.
    ELSE.
      ls_condheader-change_id  = 'D'.
    ENDIF.
    APPEND ls_condheader TO lt_condheader.

    CLEAR  ls_condheaderx.
*     ls_condheaderx-itm_number    = '000000'.
*     ls_condheaderx-COND_ST_NO    = '021'.
    ls_condheaderx-condition_nox = abap_true.
    ls_condheaderx-itm_numberx   = abap_true.
    ls_condheaderx-cond_st_nox   = abap_true.
    ls_condheaderx-cond_count    = abap_true.
    ls_condheaderx-cond_type     = abap_true.
    ls_condheaderx-change_id     = abap_true.
    APPEND ls_condheaderx TO lt_condheaderx.

    READ TABLE lt_default_condheader TRANSPORTING NO FIELDS
      WITH KEY cond_type = 'ZVA2'.
    IF sy-subrc = 0 AND ls_condheader-change_id = 'I'.
      "Clear duplicate Insert
      CLEAR: lt_condheader,
             lt_condheaderx.
    ENDIF.

* Assigns the extension fields of header
    CLEAR: ls_bapi_po,
           ls_extensionin.

    ls_bapi_po-po_number     = is_po_header-ebeln.
    ls_bapi_po-zmmapp_pernr  = is_po_header-zmmapp_pernr.
    ls_bapi_po-zmmapp_vorna  = is_po_header-zmmapp_vorna.
    ls_bapi_po-zmmapp_nach2  = is_po_header-zmmapp_nach2.
    ls_bapi_po-zmmapp_plans  = is_po_header-zmmapp_plans.
    ls_bapi_po-zmmapp_stext  = is_po_header-zmmapp_stext.
    ls_bapi_po-zmmacto_pernr = is_po_header-zmmacto_pernr.
    ls_bapi_po-zmmacto_vorna = is_po_header-zmmacto_vorna.
    ls_bapi_po-zmmacto_nach2 = is_po_header-zmmacto_nach2.
    ls_bapi_po-zmmacto_plans = is_po_header-zmmacto_plans.
    ls_bapi_po-zmmacto_stext = is_po_header-zmmacto_stext.
    ls_bapi_po-zzmm_j_1tpbupl = is_po_header-zzmm_j_1tpbupl.
    ls_bapi_po-zzmm_no_esign = is_po_header-zzmm_no_esign.

    ls_extensionin-structure = 'BAPI_TE_MEPOHEADER'.
    zcl_zlpuba001_pr=>transfer_to_extensionin(
      EXPORTING
        im_bapi_te = ls_bapi_po
      CHANGING
        cs_bapiparex = ls_extensionin ).
    APPEND ls_extensionin TO lt_extensionin.

* Assigns the fields to be updated
    CLEAR: ls_bapi_pox,
           ls_extensionin.

    ls_bapi_pox-po_number     = is_po_header-ebeln.
    ls_bapi_pox-zmmapp_pernr  = abap_true.
    ls_bapi_pox-zmmapp_vorna  = abap_true.
    ls_bapi_pox-zmmapp_nach2  = abap_true.
    ls_bapi_pox-zmmapp_plans  = abap_true.
    ls_bapi_pox-zmmapp_stext  = abap_true.
    ls_bapi_pox-zmmacto_pernr = abap_true.
    ls_bapi_pox-zmmacto_vorna = abap_true.
    ls_bapi_pox-zmmacto_nach2 = abap_true.
    ls_bapi_pox-zmmacto_plans = abap_true.
    ls_bapi_pox-zmmacto_stext = abap_true.
    ls_bapi_pox-zzmm_j_1tpbupl = abap_true.
    ls_bapi_pox-zzmm_no_esign = abap_true.

    ls_extensionin-structure = 'BAPI_TE_MEPOHEADERX'.
    zcl_zlpuba001_pr=>transfer_to_extensionin(
      EXPORTING
        im_bapi_te = ls_bapi_pox
      CHANGING
        cs_bapiparex = ls_extensionin ).
    APPEND ls_extensionin TO lt_extensionin.

    SELECT eban~banfn,
           eban~bnfpo,
           eban~knttp,
           ekpo~ebeln,
           ekpo~ebelp
      INTO TABLE @DATA(lt_pr_oa)
      FROM ekko
      INNER JOIN ekpo
        ON ekpo~ebeln = ekko~ebeln
      INNER JOIN eban
        ON eban~banfn = ekpo~banfn
       AND eban~bnfpo = ekpo~bnfpo
      FOR ALL ENTRIES IN @it_po_item
      WHERE ekko~bstyp = 'K' "OA
        AND ekpo~ebeln = @it_po_item-konnr
        AND ekpo~ebelp = @it_po_item-ktpnr.

    LOOP AT it_po_item INTO DATA(ls_po_item).
* Assigns PACKNO
      lv_packno = lv_packno + 1.

      CLEAR: lv_banfn,
             lv_bnfpo.

      lv_banfn = ls_po_item-banfn.
      lv_bnfpo = ls_po_item-bnfpo.

      IF is_po_header-bsart = '5000'.
        READ TABLE lt_pr_oa INTO DATA(ls_pr_oa)
          WITH KEY ebeln = ls_po_item-konnr
                   ebelp = ls_po_item-ktpnr.
        IF sy-subrc = 0.
          IF ls_pr_oa-knttp = 'U'.
            IF ls_po_item-pstyp = '9'.
              CLEAR: lv_banfn,
                     lv_bnfpo.
            ELSE.
              lv_banfn = ls_pr_oa-banfn.
              lv_bnfpo = ls_pr_oa-bnfpo.
            ENDIF.
          ELSE.
            lv_banfn = ls_pr_oa-banfn.
            lv_bnfpo = ls_pr_oa-bnfpo.
          ENDIF.
        ENDIF.
      ENDIF.

* Assigns the item details
      CLEAR ls_item.
      ls_item-po_item        = ls_po_item-ebelp.
      ls_item-preq_no        = lv_banfn.
      ls_item-preq_item      = lv_bnfpo.
      ls_item-agreement      = ls_po_item-konnr.
      ls_item-agmt_item      = ls_po_item-ktpnr.
      ls_item-material       = ls_po_item-matnr.
      ls_item-short_text     = ls_po_item-txz01.
      ls_item-plant          = ls_po_item-werks.
      ls_item-quantity       = ls_po_item-menge.
      ls_item-po_unit        = ls_po_item-meins.
      ls_item-matl_group     = ls_po_item-matkl.
*     ls_item-info_rec       = ls_po_item-.
      ls_item-val_type       = ls_po_item-bwtar.
      ls_item-fund           = ls_po_item-geber.
      ls_item-funds_ctr      = ls_po_item-fistl.
      ls_item-cmmt_item      = ls_po_item-fipos.
      ls_item-cmmt_item_long = ls_po_item-fipos.
      ls_item-func_area_long = ls_po_item-fkber.
      ls_item-acctasscat     = ls_po_item-knttp.
      ls_item-net_price      = ls_po_item-netpr.
      ls_item-price_unit     = ls_po_item-peinh.
      ls_item-trackingno     = ls_po_item-bednr.
      ls_item-stge_loc       = ls_po_item-lgort.
      ls_item-item_cat       = ls_po_item-pstyp.
      ls_item-funds_res      = ls_po_item-kblnr.
      ls_item-res_item       = ls_po_item-kblpos.
      ls_item-tax_code       = ls_po_item-mwskz.
      ls_item-pckg_no        = lv_packno.
      ls_item-vend_mat       = ls_po_item-idnlf.
      ls_item-delete_ind     = ls_po_item-loekz.
      APPEND ls_item TO lt_item.

* Assigns the fields to be updated
      CLEAR ls_itemx.
      ls_itemx-po_item        = ls_po_item-ebelp.
      ls_itemx-po_itemx       = abap_true.
      ls_itemx-preq_no        = abap_true.
      ls_itemx-preq_item      = abap_true.
      ls_itemx-agreement      = abap_true.
      ls_itemx-agmt_item      = abap_true.
      ls_itemx-material       = abap_true.
      ls_itemx-short_text     = abap_true.
      ls_itemx-plant          = abap_true.
      ls_itemx-quantity       = abap_true.
      ls_itemx-po_unit        = abap_true.
      ls_itemx-matl_group     = abap_true.
*     ls_itemx-info_rec       = abap_true.
      ls_itemx-val_type       = abap_true.
      ls_itemx-fund           = abap_true.
      ls_itemx-funds_ctr      = abap_true.
      ls_itemx-cmmt_item      = abap_true.
*      ls_itemx-cmmt_item_long = abap_true.
      ls_itemx-func_area_long = abap_true.
      ls_itemx-acctasscat     = abap_true.
      ls_itemx-net_price      = abap_true.
      ls_itemx-price_unit     = abap_true.
      ls_itemx-trackingno     = abap_true.
      ls_itemx-stge_loc       = abap_true.
      ls_itemx-item_cat       = abap_true.
      ls_itemx-funds_res      = abap_true.
      ls_itemx-res_item       = abap_true.
      ls_itemx-tax_code       = abap_true.
      ls_itemx-pckg_no        = abap_true.
      ls_itemx-vend_mat       = abap_true.
      ls_itemx-delete_ind     = abap_true.
      APPEND ls_itemx TO lt_itemx.

      CLEAR ls_cond.
      ls_cond-itm_number = ls_po_item-ebelp.
*       ls_cond-COND_ST_NO = '021'.
*       ls_cond-COND_COUNT = '01'.
      ls_cond-cond_type  = 'ZVA2'.

      IF ls_po_item-zva2 = abap_true.
        ls_cond-change_id  = 'I'.
      ELSE.
        ls_cond-change_id  = 'D'.
      ENDIF.
*      APPEND ls_cond TO lt_cond.

      CLEAR  ls_condx.
      ls_condx-itm_number    = ls_po_item-ebelp.
*       ls_condx-COND_ST_NO    = '021'.
      ls_condx-condition_nox = abap_true.
      ls_condx-itm_numberx   = abap_true.
      ls_condx-cond_st_nox   = abap_true.
      ls_condx-cond_count    = abap_true.
      ls_condx-cond_type     = abap_true.
      ls_condx-change_id     = abap_true.
*      APPEND ls_condx TO lt_condx.

      READ TABLE lt_default_cond TRANSPORTING NO FIELDS
        WITH KEY itm_number = ls_po_item-ebelp
                 cond_type = 'ZVA2'.
      IF sy-subrc = 0 AND ls_cond-change_id = 'I'.
        "Case duplicate Insert (Do nothing)
      ELSE.
        "Add new line
        APPEND ls_cond TO lt_cond.
        APPEND ls_condx TO lt_condx.
      ENDIF.

* Assigns delivery date
      CLEAR ls_schedule.
      ls_schedule-po_item       = ls_po_item-ebelp.
      ls_schedule-sched_line    = '0001'.
      ls_schedule-delivery_date = ls_po_item-eindt.
      ls_schedule-quantity      = ls_po_item-menge.
      ls_schedule-preq_no       = ls_po_item-banfn.
      ls_schedule-preq_item     = ls_po_item-bnfpo.
*     ls_schedule-po_date       = sy-datum.
      APPEND  ls_schedule TO lt_schedule.

* Assigns the fields to be updated
      CLEAR ls_schedulex.
      ls_schedulex-po_item       = ls_po_item-ebelp.
      ls_schedulex-sched_line    = '0001'.
      ls_schedulex-po_itemx      = abap_true.
      ls_schedulex-sched_linex   = abap_true.
      ls_schedulex-delivery_date = abap_true.
      ls_schedulex-quantity      = abap_true.
      ls_schedulex-preq_no       = abap_true.
      ls_schedulex-preq_item     = abap_true.
*     ls_schedulex-po_date       = abap_true.
      APPEND  ls_schedulex TO lt_schedulex.

* Assigns PO limits
      CLEAR ls_limits.
      ls_limits-pckg_no   = lv_packno.
      ls_limits-limit     = ls_po_item-sumlimit.
      ls_limits-no_limit  = ls_po_item-nolimit.
      ls_limits-exp_value = ls_po_item-commitment.
      ls_limits-no_frlimit = abap_true.
      APPEND ls_limits TO lt_limits.

* Assigns PO services
      CLEAR ls_services.
      ls_services-pckg_no  = lv_packno.
      ls_services-line_no  = '0000000001'.
      ls_services-ext_line = '0000000000'.
      APPEND ls_services TO lt_services.

* Assigns PO SRVACCESSVALUES
      CLEAR ls_srvaccessvalues.
      ls_srvaccessvalues-pckg_no    = lv_packno.
      ls_srvaccessvalues-line_no    = '0000000000'.
      ls_srvaccessvalues-serno_line = '01'.
*      ls_srvaccessvalues-percentage = '100'.
      ls_srvaccessvalues-serial_no  = '01'.
*      ls_srvaccessvalues-quantity   = ls_po_item-menge.
*      ls_srvaccessvalues-net_value  = ls_po_item-netpr.
      APPEND ls_srvaccessvalues TO lt_srvaccessvalues.
    ENDLOOP.

    "

* Assigns account
    LOOP AT it_po_acc_assign INTO DATA(ls_acc_assign).
      "Case Change/Add Asset
      CLEAR: ls_account.
      ls_account-po_item        = ls_acc_assign-ebelp.
      ls_account-serial_no      = ls_acc_assign-zekkn.
      ls_account-gl_account     = ls_acc_assign-sakto.
