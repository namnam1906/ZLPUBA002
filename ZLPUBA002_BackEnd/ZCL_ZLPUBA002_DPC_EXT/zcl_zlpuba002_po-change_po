        ls_accountx-cmmt_item       = abap_true.
*      ls_accountx-cmmt_item_long  = abap_true.
        ls_accountx-res_doc         = abap_true.
        ls_accountx-res_item        = abap_true.
        ls_accountx-quantity        = abap_true.
        APPEND ls_accountx TO lt_accountx.
      ENDIF.
    ENDLOOP.

* Save header text
    LOOP AT it_po_header_text INTO DATA(ls_header_text).
      CLEAR ls_textheader.
      ls_textheader-text_id = ls_header_text-tdid.
      ls_textheader-text_form = '*'.

      SPLIT ls_header_text-detail
        AT cl_abap_char_utilities=>newline
        INTO TABLE DATA(lt_text) IN CHARACTER MODE.

      IF lines( lt_text ) = 0.
        APPEND ls_textheader TO lt_textheader.   "ins
        CONTINUE.

      ELSEIF lines( lt_text ) = 1.
        ls_textheader-text_line = ls_header_text-detail.
        APPEND ls_textheader TO lt_textheader.

      ELSEIF lines( lt_text ) > 1.
        LOOP AT lt_text INTO DATA(lv_text).
          CLEAR ls_textheader-text_line.
          ls_textheader-text_line = lv_text.
          APPEND ls_textheader TO lt_textheader.
        ENDLOOP.
      ENDIF.
    ENDLOOP.

* Save item text
    LOOP AT it_po_item_text INTO DATA(ls_item_text).
      CLEAR: ls_textitem.

      ls_textitem-po_item = ls_item_text-ebelp.
      ls_textitem-text_id = ls_item_text-tdid.
      ls_textitem-text_form = '*'.

      SPLIT ls_item_text-detail
        AT cl_abap_char_utilities=>newline
        INTO TABLE lt_text IN CHARACTER MODE.

      IF lines( lt_text ) = 0.
        APPEND ls_textitem TO lt_textitem.   "ins
        CONTINUE.

      ELSEIF lines( lt_text ) = 1.
        ls_textitem-text_line = ls_item_text-detail.
        APPEND ls_textitem TO lt_textitem.

      ELSEIF lines( lt_text ) > 1.
        LOOP AT lt_text INTO lv_text.
          CLEAR ls_textitem-text_line.
          ls_textitem-text_line = lv_text.
          APPEND ls_textitem TO lt_textitem.
        ENDLOOP.
      ENDIF.
    ENDLOOP.

    DATA(ls_memory_ext) = ls_bapi_po.
    EXPORT ls_memory_ext = ls_bapi_po TO MEMORY ID 'ZLPUBA002_CHG'.

    DATA(lv_memory_extx) = abap_true.
    EXPORT lv_memory_extx = abap_true TO MEMORY ID 'ZLPUBA002_CHGX'.

    CALL FUNCTION 'BAPI_PO_CHANGE'
      EXPORTING
        purchaseorder     = ls_header-po_number
        poheader          = ls_header
        poheaderx         = ls_headerx
        memory_uncomplete = is_po_header-memory
        memory_complete   = is_po_header-memory
      IMPORTING
        expheader         = ls_expheader
        exppoexpimpheader = ls_exppoexpimpheader
      TABLES
        return            = lt_return
        poitem            = lt_item
        poitemx           = lt_itemx
        poschedule        = lt_schedule
        poschedulex       = lt_schedulex
        poaccount         = lt_account
        poaccountx        = lt_accountx
*       pocondheader      = lt_condheader
*       pocondheaderx     = lt_condheaderx
        pocond            = lt_cond
        pocondx           = lt_condx
        polimits          = lt_limits
        poservices        = lt_services
        posrvaccessvalues = lt_srvaccessvalues
        potextheader      = lt_textheader
        potextitem        = lt_textitem
        extensionin       = lt_extensionin.

    FREE MEMORY ID 'ZLPUBA002_CHG'.
    FREE MEMORY ID 'ZLPUBA002_CHGX'.

    DELETE lt_return
      WHERE id = 'BAPI' AND
            number = '001'.

    IF is_po_header-memory = abap_true AND
       is_po_header-test_run = abap_false.

      "Case hold PO
      READ TABLE lt_return INTO ls_return
      WITH KEY type = 'S'
               id = 'MEPO'
               number = '012'.
      IF sy-subrc = 0.
        COMMIT WORK AND WAIT.
      ENDIF.
      EXIT.
    ENDIF.

    READ TABLE lt_return INTO ls_return
      WITH KEY type = 'E'.
    IF sy-subrc = 0.
      LOOP AT lt_return INTO ls_return.
        IF ls_return-type = 'E' AND ls_return-id(1) = 'Z'.

          APPEND ls_return TO et_return.

          lt_msg_text = zcl_bcba_utils=>get_msg_detail( ls_return ).
          LOOP AT lt_msg_text INTO DATA(ls_msg_text).
            ls_return-message = ls_msg_text-line.
            APPEND ls_return TO et_return.
          ENDLOOP.
        ELSE.
          APPEND ls_return TO et_return.
        ENDIF.
      ENDLOOP.

      ROLLBACK WORK.
    ELSE.
      IF is_po_header-test_run = abap_true.
        ROLLBACK WORK.
        EXIT.
      ENDIF.

      COMMIT WORK AND WAIT.
    ENDIF.

  ENDMETHOD.
