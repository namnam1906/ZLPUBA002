<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns:uxap="sap.uxap"
	xmlns:layout="sap.ui.layout" xmlns:form="sap.ui.layout.form" xmlns:commons="sap.suite.ui.commons" xmlns:f="sap.f">
	<uxap:ObjectPageLayout showTitleInHeaderContent="false" showHeaderContent="true" showEditHeaderButton="false" showFooter="true"
		class="sapUiSizeCompact" toggleHeaderOnTitleClick="false">
		<uxap:headerTitle>
			<uxap:ObjectPageDynamicHeaderTitle>
				<uxap:expandedHeading>
					<FlexBox wrap="Wrap" fitContainer="true" alignItems="Center">
						<Title text="{poHeader>/EBELN}" wrapping="true" class="sapUiTinyMarginTop sapUiTinyMarginEnd"/>
						<Text text="{poHeader>/BSART_NAME}"/>
					</FlexBox>
				</uxap:expandedHeading>
				<uxap:snappedHeading>
					<FlexBox wrap="Wrap" fitContainer="true" alignItems="Center">
						<Title text="{poHeader>/EBELN}" wrapping="true" class="sapUiTinyMarginTop sapUiTinyMarginEnd"/>
						<Text text="{poHeader>/BSART_NAME}"/>
					</FlexBox>
				</uxap:snappedHeading>
			</uxap:ObjectPageDynamicHeaderTitle>
		</uxap:headerTitle>
		<uxap:headerContent>
			<FlexBox wrap="Wrap" fitContainer="true" alignItems="Stretch">
				<layout:VerticalLayout class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
					<Title text="{i18n>Label.Status}"/>
					<!--<ObjectNumber number="{ path : 'poHeader>/STATUS' , formatter : '.formatter.parseStatusText' }" unit=""-->
					<ObjectNumber number="{poHeader>/STATUS_NAME}" unit=""
						state="{path:'poHeader>/STATUS', formatter:'.formatter.parseStatus'}"/>
				</layout:VerticalLayout>
				<layout:VerticalLayout class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
					<Title text="{i18n>Label.TotalValue}"/>
					<ObjectNumber number="{path:'poHeader>/RLWRT', formatter:'.formatter.parseValue'}"
						unit="{poHeader>/WAERS}" state="Success"/>
				</layout:VerticalLayout>
				<!--<layout:VerticalLayout class="sapUiLargeMarginEnd sapUiSmallMarginBottom">-->
				<!--	<Title text="{i18n>Label.Vendor}"/>-->
				<!--	<ObjectNumber number="{poHeader>/LIFNR_NAME} ({poHeader>/LIFNR})"-->
				<!--		unit="" state="None"/>-->
				<!--</layout:VerticalLayout>-->
			</FlexBox>
		</uxap:headerContent>
		<uxap:sections>
		<uxap:ObjectPageSection title="{i18n>Label.GeneralData}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.GeneralData}">
						<uxap:blocks>
							<layout:Grid defaultSpan="XL12 L12 M12 S12">
								<layout:content>
									<form:Form>
										<form:layout>
											<form:ResponsiveGridLayout labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0"
												emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="3" columnsL="3" columnsM="2" singleContainerFullSize="false"/>
										</form:layout>
										<form:formContainers>
											<form:FormContainer title="">
												<form:formElements>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.PoDocType}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{poHeader>/BSART_NAME} ({poHeader>/BSART})"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.CompanyReference}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{= ${poHeader>/UNSEZ} !== '' ? ${poHeader>/UNSEZ} : '-' }"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="" required="false"/>
														</form:label>
														<form:fields>
															<CheckBox text="{i18n>Label.Zva2Header}" selected="{poHeader>/ZVA2}" editable="false"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="" required="false"/>
														</form:label>
														<form:fields>
															<CheckBox text="{i18n>Label.NoPrintSign}" selected="{poHeader>/ZZMM_NO_ESIGN}" editable="false"/>
														</form:fields>
													</form:FormElement>
												</form:formElements>
											</form:FormContainer>
											<form:FormContainer title="">
												<form:formElements>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.CreateBy}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{poHeader>/ERNAM_NAME}"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.CreateDate}" required="false"/>
														</form:label>
														<form:fields>
															<Text
																text="{path: 'poHeader>/BEDAT', type: 'sap.ui.model.type.Date', formatOptions: { pattern: 'dd.MM.yyyy', UTC: false, style: 'short' } }"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.BeginDate} / {i18n>Label.EndDate}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{parts: ['poHeader>/KDATB','poHeader>/KDATE'] , formatter: '.formatter.parseDatePeriod'}"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.Vendor}" required="false"/>
														</form:label>
														<form:fields>
															<Text
																text="{poHeader>/LIFNR_NAME} ({poHeader>/LIFNR})"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.VendorBranch}" required="false"/>
														</form:label>
														<form:fields>
															<Text
																text="{= ${poHeader>/ZZMM_J_1TPBUPL} !== '' ? ${parts:['poHeader>/ZZMM_J_1TPBUPL','poHeader>/J_1TPBUPL_NAME'], formatter:'.formatter.parseCodeName'} : '-' }"/>
														</form:fields>
													</form:FormElement>
												</form:formElements>
											</form:FormContainer>
											<form:FormContainer title="">
												<form:formElements>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.Company}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{poHeader>/BUKRS_NAME} ({poHeader>/BUKRS})"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.PurchasingOrg}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{poHeader>/EKORG_NAME} ({poHeader>/EKORG})"/>
														</form:fields>
													</form:FormElement>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.PurchasingGroup}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{poHeader>/EKGRP_NAME} ({poHeader>/EKGRP})"/>
														</form:fields>
													</form:FormElement>
												</form:formElements>
											</form:FormContainer>
										</form:formContainers>
									</form:Form>
								</layout:content>
							</layout:Grid>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
			<uxap:ObjectPageSection title="{i18n>Label.AuthPerson}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.AuthPerson}">
						<uxap:blocks>
							<layout:Grid defaultSpan="XL12 L12 M12 S12">
								<layout:content>
									<form:Form>
										<form:layout>
											<form:ResponsiveGridLayout labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="0"
												emptySpanL="0" emptySpanM="0" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="false"/>
										</form:layout>
										<form:formContainers>
											<form:FormContainer title="">
												<form:formElements>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.AuthPerson}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{parts: ['poHeader>/ZMMAPP_PERNR','poHeader>/ZMMAPP_VORNA','poHeader>/ZMMAPP_NACH2', 'poHeader>/ZMMAPP_STEXT'] , formatter: '.formatter.parsePerson'}">
																<!--<layoutData>-->
																<!--	<layout:GridData span="XL6 L12 M12 S12"/>-->
																<!--</layoutData>-->
															</Text>
														</form:fields>
													</form:FormElement>
												</form:formElements>
											</form:FormContainer>
											<form:FormContainer title="">
												<form:formElements>
													<form:FormElement>
														<form:label>
															<Label text="{i18n>Label.SubPerson}" required="false"/>
														</form:label>
														<form:fields>
															<Text text="{parts: ['poHeader>/ZMMACTO_PERNR','poHeader>/ZMMACTO_VORNA','poHeader>/ZMMACTO_NACH2', 'poHeader>/ZMMACTO_STEXT'] , formatter: '.formatter.parsePerson'}">
																<!--<layoutData>-->
																<!--	<layout:GridData span="XL6 L12 M12 S12"/>-->
																<!--</layoutData>-->
															</Text>
														</form:fields>
													</form:FormElement>
												</form:formElements>
											</form:FormContainer>
										</form:formContainers>
									</form:Form>
								</layout:content>
							</layout:Grid>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
			<uxap:ObjectPageSection title="{i18n>Label.LongText}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.LongText}">
						<uxap:blocks>
							<IconTabBar headerMode="Inline" upperCase="false" expandable="false" expanded="true" backgroundDesign="Transparent"
								items="{poHeaderText>/}" applyContentPadding="true" showOverflowSelectList="true" class="sapUiResponsiveContentPadding myWidth">
								<items>
									<IconTabFilter icon="sap-icon://notes" design="Horizontal"
										iconColor="{= ${poHeaderText>DETAIL} !== '' ? 'Positive' : 'Neutral'}" 
										text="{poHeaderText>TITLE}" tooltip="{poHeaderText>TITLE}"
										key="{poHeaderText>TDID}">
										<TextArea rows="5" cols="200" editable="false" value="{poHeaderText>DETAIL}" change="handleChangeLongText" />
									</IconTabFilter>
								</items>
							</IconTabBar>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
			<uxap:ObjectPageSection title="{i18n>Label.ItemList}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.ItemList}">
						<uxap:blocks>
							<Table width="100%" growing="false" mode="None" itemPress="handlePoItemPress" items="{poItem>/}">
								<headerToolbar>
								</headerToolbar>
								<columns>
									<Column width="45px" hAlign="Center" vAlign="Middle" popinDisplay="Inline" demandPopin="true" minScreenWidth="Tablet">
										<header>
											<Text text="{i18n>Label.ItemList}"/>
										</header>
									</Column>
									<Column width="auto" hAlign="Left" vAlign="Middle" demandPopin="false">
										<header>
											<VBox>
												<Text text="{i18n>Label.Material} /"/>
												<Text text="{i18n>Label.ShortText}"/>
											</VBox>
										</header>
									</Column>
									<Column width="120px" hAlign="Left" vAlign="Top" popinDisplay="Inline" demandPopin="true" minScreenWidth="Tablet">
										<header>
											<Text text="{i18n>Label.MaterialGroup}"/>
										</header>
									</Column>
									<Column width="150px" hAlign="Left" vAlign="Top" popinDisplay="Inline" demandPopin="true" minScreenWidth="Tablet">
										<header>
											<Text text="{i18n>Label.Plant}"/>
										</header>
									</Column>
									<Column width="110px" hAlign="Left" vAlign="Middle" popinDisplay="Inline" demandPopin="true" minScreenWidth="Tablet">
										<header>
											<Text text="{i18n>Label.RefDoc}"/>
										</header>
									</Column>
									<Column width="80px" hAlign="Right" vAlign="Middle" popinDisplay="Inline" demandPopin="true" minScreenWidth="Desktop">
										<header>
											<Text text="{i18n>Label.Quantity}"/>
										</header>
									</Column>
									<Column width="100px" hAlign="Right" vAlign="Middle" popinDisplay="Inline" demandPopin="true" minScreenWidth="Desktop">
										<header>
											<Text text="{i18n>Label.UnitPrice}"/>
										</header>
									</Column>
									<Column width="100px" hAlign="Right" vAlign="Middle" popinDisplay="Inline" demandPopin="true" minScreenWidth="Desktop">
										<header>
											<Text text="{i18n>Label.TotalValue}"/>
										</header>
									</Column>
								</columns>
								<items>
									<ColumnListItem type="Navigation" highlight="{path:'poItem>LOEKZ', formatter:'.formatter.formatRowHighlight'}">
										<cells>
											<Text text="{path:'poItem>EBELP', formatter:'.formatter.parseInt'}"/>
											<ObjectIdentifier title="{poItem>MATNR}" text="{poItem>TXZ01}" titleActive="false" visible="true"/>
											<ObjectIdentifier title="{poItem>MATKL}" text="{poItem>MATKL_NAME}" titleActive="false" visible="true"/>
											<ObjectIdentifier title="{poItem>WERKS}" text="{poItem>WERKS_NAME}" titleActive="false" visible="true"/>
											<!--<Text text="{poItem>BANFN} / {path:'poItem>BNFPO', formatter:'.formatter.parseInt'}" />-->
											<Link text="{parts: ['poItem>BANFN','poItem>BNFPO','poItem>KONNR','poItem>KTPNR'] , formatter: '.formatter.parseRefDoc'}"
												href="{parts: ['poItem>BANFN','poItem>BNFPO','poItem>KONNR','poItem>KTPNR'] , formatter: '.formatter.parseRefDocHref'}" 
												target="_blank" enabled="{= ${poItem>BANFN} !== '' || ${poItem>KONNR} !== ''}"/>
											<ObjectNumber
												number="{ path: 'poItem>MENGE', type: 'sap.ui.model.type.Float', formatOptions: { minFractionDigits: 2, maxFractionDigits: 2} }"
												unit="{poItem>MEINS_NAME}" emphasized="false"/>
											<ObjectNumber
												number="{ path: 'poItem>NETPR', type: 'sap.ui.model.type.Float', formatOptions: { minFractionDigits: 2, maxFractionDigits: 2} }"
												unit="{poItem>WAERS}" emphasized="false"/>
											<ObjectNumber
												number="{ path: 'poItem>RLWRT', type: 'sap.ui.model.type.Float', formatOptions: { minFractionDigits: 2, maxFractionDigits: 2} }"
												unit="{poItem>WAERS}" emphasized="false"/>
										</cells>
									</ColumnListItem>
								</items>
							</Table>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
			<uxap:ObjectPageSection title="{i18n>Label.ProcessFlow}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.ProcessFlow}">
						<uxap:blocks>
							<core:Fragment fragmentName="com.cu.s4hana.zlpuba002.view.fragment.PoProcessFlow" type="XML"/>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
			<uxap:ObjectPageSection title="{i18n>Label.Attachment}">
				<uxap:subSections>
					<uxap:ObjectPageSubSection title="{i18n>Label.Attachment}">
						<uxap:blocks>
							<UploadCollection 
								uploadEnabled="false" 
								uploadButtonInvisible="true" 
								noDataText="{i18n>Label.NoAttachment}" 
								maximumFileSize="5"
								instantUpload="false" 
								mimeType="" 
								multiple="false" 
								uploadUrl="" 
								mode="None" 
								items="{attachmentModel>/}" 
								beforeUploadStarts="handleFileBeforeUpload"
								change="handleFileChange" 
								uploadComplete="handleFileUploadComplete"
								uploadTerminated="handleFileUploadTerminate"
								fileSizeExceed="handleFileSizeExceed">
								<headerParameters/>
								<items>
									<UploadCollectionItem 
										fileName="{attachmentModel>FILE_NAME}" 
										mimeType="{attachmentModel>MIMETYPE}" 
										enableDelete="false" 
										visibleDelete="false"
										press="handleFilePress"
										deletePress="handleFileDelete">
										<attributes>
											<ObjectAttribute title="" 
												text="{parts: ['attachmentModel>CREATE_DATE','attachmentModel>CREATE_TIME'] , formatter: '.formatter.parseUploadDateTime'}"/>
											<ObjectAttribute title="" text="{attachmentModel>CREATE_BY}"/>
											<ObjectAttribute title="" 
												text="{ path : 'attachmentModel>FILE_SIZE' , formatter : '.formatter.formatFileSize' }"/>
										</attributes>
									</UploadCollectionItem>
								</items>
								<parameters/>
								<toolbar/>
							</UploadCollection>
						</uxap:blocks>
					</uxap:ObjectPageSubSection>
				</uxap:subSections>
			</uxap:ObjectPageSection>
		</uxap:sections>
		<uxap:footer></uxap:footer>
	</uxap:ObjectPageLayout>
</core:FragmentDefinition>